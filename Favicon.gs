/**
 * @fileoverview Favicon.gs — ícone da aba do navegador (escudo VigiRAM).
 *
 * POR QUE AQUI (e não num <link> no HTML): o app roda dentro de um iframe
 * sandbox do Apps Script. Um <link rel="icon"> dentro do HTML cai NO IFRAME e
 * é ignorado pela aba do navegador (o ícone vem da página de cima, gerada pelo
 * Google). O único jeito suportado é HtmlOutput.setFaviconUrl(...) no servidor,
 * que injeta o ícone na página de cima. Ver uso em Router.gs (aplicarFavicon_).
 *
 * PNG 64x64 embutido como data URI (compatível com todos os navegadores).
 * Para trocar: gere um novo PNG e substitua a string abaixo.
 */
const FAVICON_DATA_URI = "data:image/png;base64,";

/** Aplica título + favicon num HtmlOutput servido pelo doGet (Router.gs). */
function aplicarFavicon_(htmlOutput) {
  return htmlOutput.setFaviconUrl(FAVICON_DATA_URI);
}
